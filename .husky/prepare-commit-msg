#!/usr/bin/env sh
COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

if [ -n "$COMMIT_SOURCE" ]; then
  if [ "$COMMIT_SOURCE" != "message" ]; then
    exit 0
  fi

  if [ -f "$COMMIT_MSG_FILE" ] && grep -vE '^[[:space:]]*(#.*)?$' "$COMMIT_MSG_FILE" >/dev/null 2>&1; then
    exit 0
  fi
fi

API_KEY="${DEEPSEEK_API_KEY:-}"
if [ -z "$API_KEY" ] && command -v powershell.exe >/dev/null 2>&1; then
  API_KEY=$(powershell.exe -NoProfile -Command "\$key = [Environment]::GetEnvironmentVariable('DEEPSEEK_API_KEY', 'Process'); if (-not \$key) { \$key = [Environment]::GetEnvironmentVariable('DEEPSEEK_API_KEY', 'User') }; if (-not \$key) { \$key = [Environment]::GetEnvironmentVariable('DEEPSEEK_API_KEY', 'Machine') }; if (\$key) { [Console]::Write(\$key) }" 2>/dev/null | tr -d '\r')
fi

if [ -z "$API_KEY" ]; then
  echo "[ai-commit] 未设置 DEEPSEEK_API_KEY，跳过 AI 生成"
  exit 0
fi

PYTHON_BIN=""
for candidate in python3 python; do
  if command -v "$candidate" >/dev/null 2>&1 && "$candidate" -c "import json" >/dev/null 2>&1; then
    PYTHON_BIN="$candidate"
    break
  fi
done

if [ -z "$PYTHON_BIN" ]; then
  echo "[ai-commit] 未找到可用 Python，跳过 AI 生成"
  exit 0
fi

DIFF=$(git diff --cached --diff-algorithm=minimal | head -c 4000 2>/dev/null || git diff --cached --diff-algorithm=minimal | dd bs=4000 count=1 2>/dev/null || git diff --cached --diff-algorithm=minimal)

if [ -z "$DIFF" ]; then
  exit 0
fi

echo "[ai-commit] 正在生成 commit message..."

REQUEST=$(printf '%s' "$DIFF" | "$PYTHON_BIN" -c "
import json, sys
diff = sys.stdin.read()
payload = {
  'model': 'deepseek-chat',
  'max_tokens': 200,
  'temperature': 0.2,
  'messages': [
    {
      'role': 'system',
      'content': '你是一个专业的 Git commit message 生成器。根据代码变更生成一条简洁规范的 commit message。格式：<type>(<scope>): <描述>，type 选项：feat/fix/refactor/docs/test/chore，描述用中文不超过50字。只输出 commit message 本身，不要解释，不要加引号。'
    },
    {
      'role': 'user',
      'content': f'以下是本次变更的 git diff：\n\n{diff}'
    }
  ]
}
print(json.dumps(payload))
" 2>/dev/null)

RESPONSE=$(curl -s --max-time 15 \
  -H "Authorization: Bearer $API_KEY" \
  -H "Content-Type: application/json" \
  -d "$REQUEST" \
  https://api.deepseek.com/v1/chat/completions)

AI_MSG=$(echo "$RESPONSE" | "$PYTHON_BIN" -c "
import json, sys
try:
  data = json.load(sys.stdin)
  print(data['choices'][0]['message']['content'].strip())
except:
  sys.exit(1)
" 2>/dev/null)

if [ -n "$AI_MSG" ]; then
  echo "$AI_MSG" > "$COMMIT_MSG_FILE"
  echo "[ai-commit] ✓ 已生成：$AI_MSG"
else
  echo "[ai-commit] ✗ 生成失败，请手动填写"
fi
