#!/usr/bin/env sh
# =============================================================
# AI Commit Message Generator
# 触发时机：git commit 前，自动用 AI 生成 message 并预填充
# 依赖：curl、DEEPSEEK_API_KEY 环境变量
# =============================================================

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# 只在普通 commit 时运行（跳过 merge、squash、rebase）
if [ -n "$COMMIT_SOURCE" ]; then
  exit 0
fi

# 检查 API Key
if [ -z "$DEEPSEEK_API_KEY" ]; then
  echo "[ai-commit] 未设置 DEEPSEEK_API_KEY，跳过 AI 生成"
  exit 0
fi

# 获取暂存区 diff（最多 4000 字符，避免超 Token）
DIFF=$(git diff --cached --diff-algorithm=minimal | head -c 4000)

# 没有 staged 内容则跳过
if [ -z "$DIFF" ]; then
  exit 0
fi

echo "[ai-commit] 正在生成 commit message..."

# 构造请求 JSON（使用 Python 做转义，避免 jq 依赖）
REQUEST=$(python3 -c "
import json, sys
diff = sys.stdin.read()
payload = {
  'model': 'deepseek-chat',
  'max_tokens': 200,
  'temperature': 0.2,
  'messages': [
    {
      'role': 'system',
      'content': '''你是一个专业的 Git commit message 生成器。
根据代码变更生成一条简洁规范的 commit message。

格式要求（Conventional Commits）：
<type>(<scope>): <描述>

type 选项：feat/fix/refactor/docs/test/chore/style/perf
scope：变更的模块/文件名（可选）
描述：动词开头，不超过 50 字，用中文

只输出 commit message 本身，不要解释，不要加引号。'''
    },
    {
      'role': 'user',
      'content': f'以下是本次变更的 git diff：\n\n{diff}'
    }
  ]
}
print(json.dumps(payload))
" << EOF
$DIFF
EOF
)

# 调用 DeepSeek API
RESPONSE=$(curl -s --max-time 15 \
  -H "Authorization: Bearer $DEEPSEEK_API_KEY" \
  -H "Content-Type: application/json" \
  -d "$REQUEST" \
  https://api.deepseek.com/v1/chat/completions)

# 提取 message
AI_MSG=$(echo "$RESPONSE" | python3 -c "
import json, sys
try:
  data = json.load(sys.stdin)
  print(data['choices'][0]['message']['content'].strip())
except:
  sys.exit(1)
" 2>/dev/null)

# 写入 commit message 文件（保留原有内容在后面，方便手动修改）
if [ -n "$AI_MSG" ]; then
  ORIGINAL=$(cat "$COMMIT_MSG_FILE")
  printf '%s\n\n# AI 生成的 message（可直接修改）\n# 原始内容：\n# %s\n' \
    "$AI_MSG" \
    "$(echo "$ORIGINAL" | sed 's/^/# /')" > "$COMMIT_MSG_FILE"
  echo "[ai-commit] ✓ 已生成：$AI_MSG"
else
  echo "[ai-commit] ✗ 生成失败，请手动填写"
fi
